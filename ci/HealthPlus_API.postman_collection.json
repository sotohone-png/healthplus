{
  "info": {
    "name": "HealthPlus API",
    "description": "HealthPlus (AI 건강기능식품 커머스) API 테스트 컬렉션. 각 요청의 Tests 탭에 상태코드/응답값 검증 스크립트가 포함되어 있습니다. 실행 순서: 1) 회원가입/로그인 폴더 먼저 실행해서 {{accessToken}}, {{managerAccessToken}} 확보 → 2) 나머지 폴더는 순서 무관하게 실행 가능.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "managerAccessToken", "value": "" },
    { "key": "managerRefreshToken", "value": "" },
    { "key": "email", "value": "test2@test.com" },
    { "key": "password", "value": "1111" },
    { "key": "managerEmail", "value": "test@test.com" },
    { "key": "managerPassword", "value": "1111" },
    { "key": "pno", "value": "1" },
    { "key": "cino", "value": "" },
    { "key": "ono", "value": "" },
    { "key": "rno", "value": "" },
    { "key": "nno", "value": "" },
    { "key": "bno", "value": "" },
    { "key": "tno", "value": "" }
  ],
  "item": [
    {
      "name": "01. 회원 / 인증",
      "item": [
        {
          "name": "회원가입 (API-000)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"pw\": \"{{password}}\",\n  \"nickname\": \"테스트유저\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/member/join", "host": ["{{baseUrl}}"], "path": ["api", "member", "join"] }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "// 이미 가입된 이메일이면 400이 정상입니다 (중복 가입 방지 확인용)",
              "pm.test('200 또는 400 응답', function () {",
              "  pm.expect([200, 400]).to.include(pm.response.code);",
              "});"
            ]}
          }]
        },
        {
          "name": "로그인 성공 (API-001)",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "username", "value": "{{email}}" },
                { "key": "password", "value": "{{password}}" }
              ]
            },
            "url": { "raw": "{{baseUrl}}/api/member/login", "host": ["{{baseUrl}}"], "path": ["api", "member", "login"] }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('200 OK', function () { pm.response.to.have.status(200); });",
              "const data = pm.response.json();",
              "pm.test('accessToken 반환', function () { pm.expect(data.accessToken).to.exist; });",
              "if (data.accessToken) pm.collectionVariables.set('accessToken', data.accessToken);",
              "if (data.refreshToken) pm.collectionVariables.set('refreshToken', data.refreshToken);"
            ]}
          }]
        },
        {
          "name": "잘못된 비밀번호 로그인 (API-002)",
          "request": {
            "method": "POST",
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "username", "value": "{{email}}" },
                { "key": "password", "value": "wrong_password_123" }
              ]
            },
            "url": { "raw": "{{baseUrl}}/api/member/login", "host": ["{{baseUrl}}"], "path": ["api", "member", "login"] }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('401 Unauthorized', function () { pm.response.to.have.status(401); });"
            ]}
          }]
        },
        {
          "name": "매니저 로그인 (테스트용)",
          "request": {
            "method": "POST",
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "username", "value": "{{managerEmail}}" },
                { "key": "password", "value": "{{managerPassword}}" }
              ]
            },
            "url": { "raw": "{{baseUrl}}/api/member/login", "host": ["{{baseUrl}}"], "path": ["api", "member", "login"] }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "const data = pm.response.json();",
              "if (data.accessToken) pm.collectionVariables.set('managerAccessToken', data.accessToken);",
              "if (data.refreshToken) pm.collectionVariables.set('managerRefreshToken', data.refreshToken);"
            ]}
          }]
        },
        {
          "name": "토큰 갱신 (API-003)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/member/refresh?refreshToken={{refreshToken}}",
              "host": ["{{baseUrl}}"], "path": ["api", "member", "refresh"],
              "query": [{ "key": "refreshToken", "value": "{{refreshToken}}" }]
            }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('200 OK', function () { pm.response.to.have.status(200); });",
              "const data = pm.response.json();",
              "pm.test('새 accessToken 반환', function () { pm.expect(data.accessToken).to.exist; });",
              "if (data.accessToken) pm.collectionVariables.set('accessToken', data.accessToken);"
            ]}
          }]
        }
      ]
    },
    {
      "name": "02. 상품",
      "item": [
        {
          "name": "상품 목록 조회 (API-004)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/products/list?page=1&size=10", "host": ["{{baseUrl}}"], "path": ["api", "products", "list"], "query": [{"key":"page","value":"1"},{"key":"size","value":"10"}] }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('200 OK, 토큰 없이도 조회됨', function () { pm.response.to.have.status(200); });",
            "const data = pm.response.json();",
            "if (data.dtoList && data.dtoList.length > 0) pm.collectionVariables.set('pno', data.dtoList[0].pno);"
          ]}}]
        },
        {
          "name": "상품 상세 조회 (API-005)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/products/{{pno}}", "host": ["{{baseUrl}}"], "path": ["api", "products", "{{pno}}"] }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('200 OK', function () { pm.response.to.have.status(200); });"
          ]}}]
        },
        {
          "name": "상품 검색",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/products/search?keyword=비타민&page=1&size=10", "host": ["{{baseUrl}}"], "path": ["api", "products", "search"], "query": [{"key":"keyword","value":"비타민"},{"key":"page","value":"1"},{"key":"size","value":"10"}] }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('200 OK', function () { pm.response.to.have.status(200); });"
          ]}}]
        },
        {
          "name": "카테고리 필터 조회 (BUG-014 회귀)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/products/category?category=비타민&page=1&size=10", "host": ["{{baseUrl}}"], "path": ["api", "products", "category"], "query": [{"key":"category","value":"비타민"},{"key":"page","value":"1"},{"key":"size","value":"10"}] }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('200 OK - ERROR_ACCESS_TOKEN 아님 (BUG-014 회귀 확인)', function () { pm.response.to.have.status(200); });"
          ]}}]
        },
        {
          "name": "비회원 상품 목록 접근 - 참고용 (API-006, 실제로는 토큰 없이도 200)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/products/list?page=1&size=10", "host": ["{{baseUrl}}"], "path": ["api", "products", "list"], "query": [{"key":"page","value":"1"},{"key":"size","value":"10"}] }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "// 상품 목록은 JWTCheckFilter에서 제외된 공개 API라 실제로는 200이 정상입니다.",
            "// 문서(API-006)의 'ERROR_ACCESS_TOKEN' 기대값과 실제 동작이 다른지 여기서 확인하세요.",
            "pm.test('상태 코드 기록', function () { console.log('status:', pm.response.code); });"
          ]}}]
        },
        {
          "name": "[MANAGER] 상품 수정 - PUT /api/products/{pno} (인증 필요, BUG-018 회귀)",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{managerAccessToken}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "pname", "value": "수정된 상품명", "type": "text" },
                { "key": "pdesc", "value": "수정된 설명", "type": "text" },
                { "key": "price", "value": "10000", "type": "text" },
                { "key": "category", "value": "비타민", "type": "text" }
              ]
            },
            "url": { "raw": "{{baseUrl}}/api/products/{{pno}}", "host": ["{{baseUrl}}"], "path": ["api", "products", "{{pno}}"] }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('MANAGER 토큰이면 200, 인증 정상 작동 확인', function () { pm.response.to.have.status(200); });"
          ]}}]
        },
        {
          "name": "[USER] 상품 수정 시도 - 403 기대 (권한 검증)",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "pname", "value": "일반유저 수정시도", "type": "text" }
              ]
            },
            "url": { "raw": "{{baseUrl}}/api/products/{{pno}}", "host": ["{{baseUrl}}"], "path": ["api", "products", "{{pno}}"] }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "// 주의: 현재 백엔드에 @PreAuthorize가 없는 상태라면(BUG-012 참고) 이 테스트는 실패(200)할 수 있습니다.",
            "// @PreAuthorize 복원 후 재실행해서 403이 나오는지 반드시 확인하세요.",
            "pm.test('일반 USER는 403이어야 함 (@PreAuthorize 복원 필요 - BUG-012)', function () {",
            "  pm.response.to.have.status(403);",
            "});"
          ]}}]
        }
      ]
    },
    {
      "name": "03. 장바구니",
      "item": [
        {
          "name": "장바구니 담기 (API-008)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"{{email}}\",\n  \"pno\": {{pno}},\n  \"qty\": 2\n}" },
            "url": { "raw": "{{baseUrl}}/api/cart/change", "host": ["{{baseUrl}}"], "path": ["api", "cart", "change"] }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('200 OK', function () { pm.response.to.have.status(200); });",
            "const data = pm.response.json();",
            "const item = data.find(i => i.pno == pm.collectionVariables.get('pno'));",
            "if (item) pm.collectionVariables.set('cino', item.cino);"
          ]}}]
        },
        {
          "name": "장바구니 조회 (API-007)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/cart/items", "host": ["{{baseUrl}}"], "path": ["api", "cart", "items"] }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('200 OK', function () { pm.response.to.have.status(200); });"
          ]}}]
        },
        {
          "name": "비회원 장바구니 접근 (API-009)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/cart/items", "host": ["{{baseUrl}}"], "path": ["api", "cart", "items"] }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('401 Unauthorized (토큰 없음)', function () { pm.response.to.have.status(401); });"
          ]}}]
        },
        {
          "name": "장바구니 삭제 - cino로 삭제 (BUG-017 회귀)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"{{email}}\",\n  \"cino\": {{cino}},\n  \"pno\": {{pno}},\n  \"qty\": 0\n}" },
            "url": { "raw": "{{baseUrl}}/api/cart/change", "host": ["{{baseUrl}}"], "path": ["api", "cart", "change"] }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('200 OK', function () { pm.response.to.have.status(200); });",
            "const data = pm.response.json();",
            "pm.test('삭제한 cino가 목록에서 사라짐 (BUG-017 회귀 확인)', function () {",
            "  const stillExists = data.some(i => i.cino == pm.collectionVariables.get('cino'));",
            "  pm.expect(stillExists).to.be.false;",
            "});"
          ]}}]
        },
        {
          "name": "장바구니 삭제 - cino 없이 시도 (BUG-017 원래 버그 재현용)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"{{email}}\",\n  \"pno\": {{pno}},\n  \"qty\": 0\n}" },
            "url": { "raw": "{{baseUrl}}/api/cart/change", "host": ["{{baseUrl}}"], "path": ["api", "cart", "change"] }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "// cino 없이 삭제 시도 시 서버가 어떻게 반응하는지 기록 (500 에러 or graceful fail 여부 확인용)",
            "pm.test('응답 상태 기록', function () { console.log('status:', pm.response.code, pm.response.text()); });"
          ]}}]
        }
      ]
    },
    {
      "name": "04. 주문",
      "item": [
        {
          "name": "주문 생성 (API-010)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"{{email}}\",\n  \"orderItems\": [{ \"pno\": {{pno}}, \"qty\": 1 }],\n  \"receiver\": \"홍길동\",\n  \"phone\": \"010-1234-5678\",\n  \"zipcode\": \"12345\",\n  \"address\": \"서울시 강남구\",\n  \"addressDetail\": \"101호\",\n  \"deliveryRequest\": \"문 앞에 놔주세요\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/order/", "host": ["{{baseUrl}}"], "path": ["api", "order", ""] }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('200 OK, ono 반환', function () {",
            "  pm.response.to.have.status(200);",
            "  const data = pm.response.json();",
            "  pm.expect(data.ono).to.exist;",
            "  pm.collectionVariables.set('ono', data.ono);",
            "});"
          ]}}]
        },
        {
          "name": "주문 목록 조회 (API-011)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/order/list/{{email}}", "host": ["{{baseUrl}}"], "path": ["api", "order", "list", "{{email}}"] }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('200 OK', function () { pm.response.to.have.status(200); });"
          ]}}]
        },
        {
          "name": "주문 상세 조회",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/order/{{ono}}", "host": ["{{baseUrl}}"], "path": ["api", "order", "{{ono}}"] }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('200 OK, 배송정보 저장 확인 (구 TC-061)', function () {",
            "  pm.response.to.have.status(200);",
            "  const data = pm.response.json();",
            "  pm.expect(data.receiver).to.exist;",
            "  pm.expect(data.address).to.exist;",
            "});"
          ]}}]
        },
        {
          "name": "주문 취소 (API-012)",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/order/cancel/{{ono}}", "host": ["{{baseUrl}}"], "path": ["api", "order", "cancel", "{{ono}}"] }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('200 OK', function () { pm.response.to.have.status(200); });"
          ]}}]
        },
        {
          "name": "비회원 주문 시도 (API-013)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"{{email}}\",\n  \"orderItems\": [{ \"pno\": {{pno}}, \"qty\": 1 }]\n}" },
            "url": { "raw": "{{baseUrl}}/api/order/", "host": ["{{baseUrl}}"], "path": ["api", "order", ""] }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('401 Unauthorized', function () { pm.response.to.have.status(401); });"
          ]}}]
        }
      ]
    },
    {
      "name": "05. 리뷰",
      "item": [
        {
          "name": "리뷰 작성 (API-014)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"pno\": {{pno}},\n  \"email\": \"{{email}}\",\n  \"nickname\": \"테스트유저\",\n  \"content\": \"좋은 제품이에요\",\n  \"rating\": 5\n}" },
            "url": { "raw": "{{baseUrl}}/api/review/", "host": ["{{baseUrl}}"], "path": ["api", "review", ""] }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('200 OK, rno 반환', function () {",
            "  pm.response.to.have.status(200);",
            "  const data = pm.response.json();",
            "  pm.expect(data.rno).to.exist;",
            "  pm.collectionVariables.set('rno', data.rno);",
            "});"
          ]}}]
        },
        {
          "name": "리뷰 목록 조회 (API-015)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/review/list/{{pno}}", "host": ["{{baseUrl}}"], "path": ["api", "review", "list", "{{pno}}"] }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('200 OK, 토큰 없이도 조회됨', function () { pm.response.to.have.status(200); });"
          ]}}]
        },
        {
          "name": "본인 리뷰 삭제 (API-016)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/review/{{rno}}?email={{email}}", "host": ["{{baseUrl}}"], "path": ["api", "review", "{{rno}}"], "query": [{"key":"email","value":"{{email}}"}] }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('200 OK', function () { pm.response.to.have.status(200); });"
          ]}}]
        },
        {
          "name": "타인 리뷰 삭제 시도 (API-017)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{managerAccessToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/review/{{rno}}?email=other@test.com", "host": ["{{baseUrl}}"], "path": ["api", "review", "{{rno}}"], "query": [{"key":"email","value":"other@test.com"}] }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "// 문서상 기대값은 500(권한오류)로 되어있으나, 정상적인 REST 설계라면 403이 맞습니다.",
